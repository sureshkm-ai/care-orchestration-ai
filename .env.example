# Application Mode: "local" or "aws"
APP_ENV=local
LOG_LEVEL=DEBUG

# Security - CHANGE THESE IN PRODUCTION
JWT_SECRET_KEY=dev-only-change-in-production-min-32-chars!!
JWT_ALGORITHM=HS256
JWT_AUDIENCE=care-orchestration-ai
JWT_TOKEN_LIFETIME_SECONDS=3600
ENCRYPTION_KEY=dev-only-change-in-production-32b!

# Agent Ports (A2A servers)
TRIAGE_AGENT_PORT=9001
CARE_COORDINATOR_AGENT_PORT=9002

# MCP Server Ports
FHIR_MCP_PORT=8001
SCHEDULING_MCP_PORT=8003

# Database (local mode)
DATABASE_DIR=./data/db

# AWS Configuration (aws mode only)
# AWS_REGION=us-east-1
# HEALTHLAKE_DATASTORE_ID=
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID_TRIAGE=
# COGNITO_CLIENT_ID_CARE_COORDINATOR=
# KMS_KEY_ID=
# DYNAMODB_TABLE_PREFIX=care-orchestration-ai
# LINEAGE_S3_BUCKET=
# AUDIT_S3_BUCKET=
